{
  "swagger": "2.0",
  "info": {
    "title": "AI饮食识别系统 API",
    "version": "1.0.0",
    "description": "基于 Spring Boot 的识别/会话/日志/用户/分析接口"
  },
  "schemes": ["http"],
  "basePath": "/",
  "consumes": ["application/json", "multipart/form-data"],
  "produces": ["application/json"],
  "paths": {
    "/recognition/recognize": {
      "post": {
        "summary": "多图识别",
        "consumes": ["multipart/form-data"],
        "parameters": [
          { "name": "mealType", "in": "formData", "type": "string", "required": false },
          { "name": "prompt", "in": "formData", "type": "string", "required": false },
          { "name": "files", "in": "formData", "type": "file", "required": true, "collectionFormat": "multi" }
        ],
        "responses": {
          "200": { "description": "OK", "schema": { "$ref": "#/definitions/RecognitionResponseDTO" } }
        }
      }
    },
    "/recognition/refine": {
      "post": {
        "summary": "二次识别",
        "parameters": [
          { "in": "body", "name": "body", "required": true, "schema": { "$ref": "#/definitions/RefineRequestDTO" } }
        ],
        "responses": {
          "200": { "description": "OK", "schema": { "$ref": "#/definitions/ImageNutritionDTO" } }
        }
      }
    },
    "/session/list": {
      "get": {
        "summary": "会话列表",
        "parameters": [
          { "name": "page", "in": "query", "type": "integer", "required": true },
          { "name": "pageSize", "in": "query", "type": "integer", "required": true },
          { "name": "date", "in": "query", "type": "string", "format": "date", "required": false }
        ],
        "responses": {
          "200": { "description": "OK", "schema": { "$ref": "#/definitions/PageSessionList" } }
        }
      }
    },
    "/session/{id}": {
      "get": {
        "summary": "会话详情",
        "parameters": [{ "name": "id", "in": "path", "type": "integer", "required": true }],
        "responses": {
          "200": { "description": "OK", "schema": { "$ref": "#/definitions/Session" } }
        }
      },
      "delete": {
        "summary": "删除会话",
        "parameters": [{ "name": "id", "in": "path", "type": "integer", "required": true }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/session/{id}/mealType": {
      "put": {
        "summary": "修改餐别",
        "parameters": [
          { "name": "id", "in": "path", "type": "integer", "required": true },
          { "in": "body", "name": "body", "required": true, "schema": { "$ref": "#/definitions/UpdateMealTypeRequest" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/diet-log": {
      "get": {
        "summary": "获取某日饮食",
        "parameters": [{ "name": "date", "in": "query", "type": "string", "format": "date", "required": true }],
        "responses": { "200": { "description": "OK", "schema": { "$ref": "#/definitions/DietLog" } } }
      }
    },
    "/diet-log/history": {
      "get": {
        "summary": "历史饮食",
        "responses": { "200": { "description": "OK", "schema": { "type": "array", "items": { "$ref": "#/definitions/DietLog" } } } }
      }
    },
    "/user/login": {
      "post": {
        "summary": "登录",
        "parameters": [{ "in": "body", "name": "body", "required": true, "schema": { "$ref": "#/definitions/UserLoginDTO" } }],
        "responses": { "200": { "description": "OK", "schema": { "$ref": "#/definitions/UserLoginVO" } } }
      }
    },
    "/user/user/profile/{userId}": {
      "get": {
        "summary": "获取用户信息",
        "parameters": [{ "name": "userId", "in": "path", "type": "integer", "required": true }],
        "responses": { "200": { "description": "OK", "schema": { "$ref": "#/definitions/UserProfile" } } }
      }
    },
    "/user/user/profile": {
      "put": {
        "summary": "更新用户信息",
        "parameters": [{ "in": "body", "name": "body", "required": true, "schema": { "$ref": "#/definitions/UserProfile" } }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/user/user/body/{userId}": {
      "get": {
        "summary": "获取身体信息",
        "parameters": [{ "name": "userId", "in": "path", "type": "integer", "required": true }],
        "responses": { "200": { "description": "OK", "schema": { "$ref": "#/definitions/UserBodyProfile" } } }
      }
    },
    "/user/user/body": {
      "put": {
        "summary": "更新身体信息",
        "parameters": [{ "in": "body", "name": "body", "required": true, "schema": { "$ref": "#/definitions/UserBodyProfile" } }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/analytics/calories": {
      "get": {
        "summary": "热量趋势",
        "responses": { "200": { "description": "OK", "schema": { "type": "array", "items": { "$ref": "#/definitions/CaloriesTrendPoint" } } } }
      }
    },
    "/analytics/nutrition": {
      "get": {
        "summary": "营养比例",
        "responses": { "200": { "description": "OK", "schema": { "$ref": "#/definitions/NutritionRatioDTO" } } }
      }
    },
    "/analytics/advice": {
      "get": {
        "summary": "每日建议",
        "responses": { "200": { "description": "OK", "schema": { "type": "array", "items": { "type": "string" } } } }
      }
    }
  },
  "definitions": {
    "RecognitionResponseDTO": {
      "type": "object",
      "properties": {
        "sessionId": { "type": "integer", "format": "int64" },
        "totalCalories": { "type": "number" },
        "protein": { "type": "number" },
        "fat": { "type": "number" },
        "carbs": { "type": "number" },
        "images": {
          "type": "array",
          "items": { "$ref": "#/definitions/ImageNutritionDTO" }
        }
      }
    },
    "ImageNutritionDTO": {
      "type": "object",
      "properties": {
        "imageId": { "type": "integer", "format": "int64" },
        "imageUrl": { "type": "string" },
        "totalCalories": { "type": "number" },
        "protein": { "type": "number" },
        "fat": { "type": "number" },
        "carbs": { "type": "number" }
      }
    },
    "RefineRequestDTO": {
      "type": "object",
      "properties": {
        "sessionId": { "type": "integer", "format": "int64" },
        "imageId": { "type": "integer", "format": "int64" },
        "extraInfo": { "type": "string" }
      },
      "required": ["imageId"]
    },
    "PageSessionList": {
      "type": "object",
      "properties": {
        "total": { "type": "integer", "format": "int64" },
        "records": {
          "type": "array",
          "items": { "$ref": "#/definitions/SessionListDTO" }
        }
      }
    },
    "SessionListDTO": {
      "type": "object",
      "properties": {
        "id": { "type": "integer", "format": "int64" },
        "mealType": { "type": "string" },
        "totalCalories": { "type": "number" },
        "createTime": { "type": "string", "format": "date-time" }
      }
    },
    "Session": {
      "type": "object",
      "properties": {
        "id": { "type": "integer", "format": "int64" },
        "userId": { "type": "integer", "format": "int64" },
        "mealType": { "type": "string" },
        "totalCalories": { "type": "number" },
        "protein": { "type": "number" },
        "fat": { "type": "number" },
        "carbs": { "type": "number" },
        "status": { "type": "string" },
        "createTime": { "type": "string", "format": "date-time" }
      }
    },
    "DietLog": {
      "type": "object",
      "properties": {
        "id": { "type": "integer", "format": "int64" },
        "userId": { "type": "integer", "format": "int64" },
        "date": { "type": "string", "format": "date" },
        "totalCalories": { "type": "number" },
        "protein": { "type": "number" },
        "fat": { "type": "number" },
        "carbs": { "type": "number" }
      }
    },
    "UserLoginDTO": {
      "type": "object",
      "properties": {
        "loginType": { "type": "string" },
        "account": { "type": "string" },
        "password": { "type": "string" },
        "code": { "type": "string" }
      }
    },
    "UserLoginVO": {
      "type": "object",
      "properties": {
        "id": { "type": "integer", "format": "int64" },
        "token": { "type": "string" }
      }
    },
    "UserProfile": {
      "type": "object",
      "properties": {
        "id": { "type": "integer", "format": "int64" },
        "userId": { "type": "integer", "format": "int64" },
        "nickname": { "type": "string" },
        "avatar": { "type": "string" },
        "gender": { "type": "integer", "format": "int32" }
      }
    },
    "UserBodyProfile": {
      "type": "object",
      "properties": {
        "id": { "type": "integer", "format": "int64" },
        "userId": { "type": "integer", "format": "int64" },
        "height": { "type": "number" },
        "weight": { "type": "number" },
        "bodyFat": { "type": "number" },
        "age": { "type": "integer", "format": "int32" },
        "bmi": { "type": "number" },
        "bmr": { "type": "number" },
        "targetCalories": { "type": "number" }
      }
    },
    "UpdateMealTypeRequest": {
      "type": "object",
      "properties": { "mealType": { "type": "string" } },
      "required": ["mealType"]
    },
    "CaloriesTrendPoint": {
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "calories": { "type": "number" }
      }
    },
    "NutritionRatioDTO": {
      "type": "object",
      "properties": {
        "proteinRatio": { "type": "number" },
        "fatRatio": { "type": "number" },
        "carbsRatio": { "type": "number" }
      }
    }
  }
}
